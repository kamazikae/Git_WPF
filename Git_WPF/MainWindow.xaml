<Window x:Class="Git_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Git_WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel>
            <TextBox x:Name="TbNumberOne"/>
            <TextBox x:Name="TbNumberTwo"/>
            <Button x:Name="BtAdd" Click="BtAdd_Click" 
                    Content="Сложить"/>
            <Button x:Name="BtMultiply" Click="BtMultiply_Click"
                    Content="Умножить"/>
            <TextBlock x:Name="TblResult"/>
        </StackPanel>
    </Grid>
</Window>
